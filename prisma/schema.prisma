generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── KNOWLEDGE LAYER ───

model Node {
  id          String @id @default(cuid())
  type        String // concept, technology, language, framework, tool, paradigm, school, roadmap
  slug        String @unique
  name        String
  description String?
  metadata    String? // JSON: flexible extras
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  outgoingEdges   Edge[]              @relation("SourceNode")
  incomingEdges   Edge[]              @relation("TargetNode")
  roadmapSteps    RoadmapStep[]
  userNodeProgress UserNodeProgress[]
}

model Edge {
  id           String @id @default(cuid())
  sourceId     String
  targetId     String
  relationType String // requires, teaches, tests, references, part_of, extends, related_to, recommends, precedes, alternative_to
  strength     Int    @default(5)

  source Node @relation("SourceNode", fields: [sourceId], references: [id], onDelete: Cascade)
  target Node @relation("TargetNode", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, relationType])
  @@index([sourceId])
  @@index([targetId])
}

model Roadmap {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  description    String?
  type           String   // system, user, ai
  goal           String?
  difficulty     String?
  estimatedHours Int?
  metadata       String?  // JSON
  createdAt      DateTime @default(now())

  steps    RoadmapStep[]
}

model RoadmapStep {
  id        String  @id @default(cuid())
  roadmapId String
  nodeId    String
  order     Int
  optional  Boolean @default(false)

  roadmap Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  node    Node    @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([roadmapId, nodeId])
}

// ─── LEARNING LAYER (Resources) ───

model Volume {
  id          String   @id @default(cuid())
  number      Int      @unique
  slug        String   @unique
  title       String
  subtitle    String?
  description String
  icon        String?
  color       String?
  status      String   @default("active")
  order       Int      @default(0)
  nodeId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories   Category[]
  enrollments  Enrollment[]
  projects     Project[]
  certificates Certificate[]
}

model Category {
  id        String   @id @default(cuid())
  volumeId   String
  slug      String
  title     String
  description String?
  icon      String?
  order     Int      @default(0)
  nodeId    String?
  createdAt DateTime @default(now())

  volume  Volume   @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  modules Module[]
}

model Module {
  id         String   @id @default(cuid())
  categoryId String
  slug       String
  title      String
  description String?
  order      Int      @default(0)
  nodeId     String?
  createdAt  DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  lessons  Lesson[]
}

model Lesson {
  id            String   @id @default(cuid())
  moduleId      String
  slug          String   @unique
  title         String
  description   String?
  contentPath   String
  contentType   String   @default("text")
  order         Int      @default(0)
  duration      Int?
  xpReward      Int      @default(10)
  difficulty    String   @default("beginner")
  tags          String   @default("[]") // JSON array
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  module       Module            @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  completions  LessonCompletion[]
  bookmarks    Bookmark[]
  notes        Note[]
  quizzes      QuizQuestion[]
  versions     LessonVersion[]
}

model LessonVersion {
  id          String   @id @default(cuid())
  lessonId    String
  version     Int
  contentPath String
  status      String   @default("draft") // draft, published, archived
  changelog   String?
  createdAt   DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, version])
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  difficulty  String   @default("beginner")
  volumeId    String?
  template    String?
  nodeId      String?
  createdAt   DateTime @default(now())

  volume      Volume?              @relation(fields: [volumeId], references: [id])
  submissions ProjectSubmission[]
}

model QuizQuestion {
  id          String   @id @default(cuid())
  lessonId    String?
  challengeId String?
  question    String
  type        String   @default("mcq")
  options     String?  // JSON array
  answer      String
  explanation String?
  nodeId      String?
  createdAt   DateTime @default(now())

  lesson    Lesson?        @relation(fields: [lessonId], references: [id])
  attempts  QuizAttempt[]
}

model Challenge {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  difficulty  String   @default("beginner")
  category    String?
  type        String   @default("daily")
  starterCode String?
  testCases   String   // JSON
  xpReward    Int      @default(50)
  timeLimit   Int?
  nodeId      String?
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())

  submissions ChallengeSubmission[]
}

// ─── USER LAYER ───

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  username  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stats              UserStats?
  enrollments        Enrollment[]
  completions        LessonCompletion[]
  bookmarks          Bookmark[]
  notes              Note[]
  quizAttempts       QuizAttempt[]
  challengeSubs      ChallengeSubmission[]
  projectSubs        ProjectSubmission[]
  userAchievements   UserAchievement[]
  certificates       Certificate[]
  posts              Post[]
  comments           Comment[]
  likes              Like[]
  terminalSessions   TerminalSession[]
  notifications      Notification[]
  notificationPrefs  NotificationPreference[]
  assets             Asset[]
  learningPaths      UserLearningPath[]
  nodeProgress       UserNodeProgress[]
}

model UserStats {
  id         String   @id @default(cuid())
  userId     String   @unique
  xp         Int      @default(0)
  level      Int      @default(1)
  streak     Int      @default(0)
  lastActive DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  volumeId   String
  status     String   @default("enrolled")
  startedAt  DateTime @default(now())
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  volume Volume @relation(fields: [volumeId], references: [id], onDelete: Cascade)
}

model LessonCompletion {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean  @default(true)
  xpEarned  Int      @default(0)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model UserLearningPath {
  id        String   @id @default(cuid())
  userId    String
  roadmapId String?
  goal      String?
  mode      String   @default("guided") // guided, explorer, ai
  status    String   @default("active")
  startedAt DateTime @default(now())

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress UserNodeProgress[]
}

model UserNodeProgress {
  id           String   @id @default(cuid())
  userId       String
  nodeId       String
  pathId       String?
  status       String   @default("locked") // locked, available, in_progress, completed
  confidence   Int?     // 0-100
  completedAt  DateTime?
  lastActivity DateTime?

  user User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  path UserLearningPath? @relation(fields: [pathId], references: [id])
  node Node              @relation(fields: [nodeId], references: [id])
}

model Achievement {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  icon        String?
  xpReward    Int      @default(0)
  criteria    String   // JSON
  createdAt   DateTime @default(now())

  users UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  answer     String
  correct    Boolean
  createdAt  DateTime @default(now())

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model ChallengeSubmission {
  id          String   @id @default(cuid())
  userId      String
  challengeId String
  code        String
  passed      Boolean  @default(false)
  score       Int?
  submittedAt DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
}

model ProjectSubmission {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  title       String?
  repoUrl     String?
  demoUrl     String?
  files       String?  // JSON
  submittedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Certificate {
  id        String   @id @default(cuid())
  userId    String
  title     String
  volumeId  String?
  type      String   @default("volume")
  issuedAt  DateTime @default(now())
  expiresAt DateTime?
  metadata  String   // JSON

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  volume Volume? @relation(fields: [volumeId], references: [id])
}

model Post {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  type      String   @default("discussion")
  tags      String   @default("[]")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments Comment[]
  likes    Like[]
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String?
  read      Boolean  @default(false)
  data      String?  // JSON
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationPreference {
  id     String @id @default(cuid())
  userId String @unique
  email  Boolean @default(true)
  push   Boolean @default(true)
  inApp  Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TerminalSession {
  id        String   @id @default(cuid())
  userId    String
  language  String   @default("javascript")
  state     String?  // JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Asset {
  id         String   @id @default(cuid())
  filename   String
  url        String
  type       String   @default("image")
  size       Int?
  tags       String   @default("[]")
  uploadedAt DateTime @default(now())

  userId String?
  user   User?    @relation(fields: [userId], references: [id])
}
